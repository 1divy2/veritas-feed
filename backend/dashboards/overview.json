{
  "annotations": { "list": [] },
  "title": "VERITAS//FEED — Overview (placeholder)",
  "panels": [
    {
      "title": "Messages processed / min",
      "type": "stat",
      "targets": [{ "expr": "sum(rate(veritas_messages_processed_total[1m])) * 60" }]
    },
    {
      "title": "LLM latency p95",
      "type": "stat",
      "targets": [{ "expr": "histogram_quantile(0.95, rate(veritas_llm_seconds_bucket[5m]))" }]
    },
    {
      "title": "Risk distribution",
      "type": "piechart",
      "targets": [{ "expr": "sum by (risk_level) (veritas_risk_distribution_total)" }]
    }
  ],
  "schemaVersion": 38,
  "version": 1
}
